  subtitleFontSize: 42
  cutsceneTexts:
  - "\uCD9C\uAD6C \uC55E\uC5D0 \uB2E4\uB2E4\uB974\uC790, \uACE0\uC694\uD558\uB358
    \uBB38\uC591\uC774 \uCC9C\uCC9C\uD788 \uBE5B\uC744 \uB760\uAE30 \uC2DC\uC791\uD588\uB2E4.\n\uD769\uC5B4\uC838
    \uC788\uB358 \uC120\uC728\uC774 \uC774\uACF3\uC73C\uB85C \uBAA8\uC5EC\uB4DC\uB294
    \uB4EF\uD55C \uAE30\uBD84\uC774 \uB4E0\uB2E4."
  - "\uBE5B\uC73C\uB85C \uBB3C\uB4E0 \uCD9C\uAD6C \uB108\uBA38\uB85C, \uB2E4\uC74C
    \uC120\uC728\uC774 \uC870\uC6A9\uD788 \uC774\uC5B4\uC9C0\uACE0 \uC788\uB2E4.\n\uC774\uC81C
    \uADF8 \uD750\uB984\uC744 \uB530\uB77C, \uC800 \uB108\uBA38\uB85C \uB098\uC544\uAC08
    \uCC28\uB840\uB2E4."
