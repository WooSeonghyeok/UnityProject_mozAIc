  - dialogueId: EP3_001
    speakerType: Narration
    speakerName: 
    subtitleText: "\uC774\uACF3\uC740 \uC804\uC5D0 \uC9C0\uB098\uC628 \uACF5\uAC04\uB4E4\uACFC\uB294
      \uBD84\uC704\uAE30\uAC00 \uB2E4\uB974\uB2E4."
    showSpeakerName: 0
    cameraPosition: {x: 2.7829013, y: 2.1086717, z: -8.384186}
    lookAtPosition: {x: 0.4364586, y: 1.682951, z: 2.8275914}
    moveDuration: 1.8
    holdDuration: 1.5
    fieldOfView: 54
  - dialogueId: EP3_002
    speakerType: Narration
    speakerName: 
    subtitleText: "\uBC1C\uBC11\uC5D0\uB294 \uD669\uD63C\uBE5B \uAD6C\uB984\uC774
      \uB0AE\uAC8C \uAE54\uB824 \uC788\uACE0, \uC8FC\uBCC0\uC5D0\uB294 \uD769\uC5B4\uC9C4
      \uC74C\uD45C\uC640 \uC120\uC728\uC758 \uD754\uC801\uC774 \uB5A0\uB2E4\uB2CC\uB2E4."
    showSpeakerName: 0
    cameraPosition: {x: -0.84414005, y: 5.0954046, z: 2.9775188}
