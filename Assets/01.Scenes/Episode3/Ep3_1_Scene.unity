  - dialogueId: EP3_001
    speakerType: Narration
    speakerName: 
    subtitleText: "\uBB50\uC57C..? \uBD84\uBA85 \uC791\uC5C5\uC2E4\uC774\uC5C8\uB294\uB370?"
    showSpeakerName: 0
    cameraPosition: {x: 4.8597326, y: -2.3806152, z: 20.503187}
    lookAtPosition: {x: 5.4538097, y: -2.7240057, z: 17.524256}
    moveDuration: 1.8
    holdDuration: 1.5
    fieldOfView: 54
  - dialogueId: EP3_002
    speakerType: Monologue
    speakerName: 
    subtitleText: "\uACF5\uC5F0\uC7A5\uC5D4 \uD769\uC5B4\uC9C4 \uC545\uBCF4 \uC870\uAC01\uB4E4\uC774,
      \uC78A\uD78C \uAE30\uC5B5\uC758 \uD30C\uD3B8\uCC98\uB7FC \uACF3\uACF3\uC5D0
      \uB0A8\uC544 \uC788\uB2E4."
    showSpeakerName: 0
    cameraPosition: {x: 6.3582244, y: -2.0885935, z: 11.246157}
    lookAtPosition: {x: 6.3213096, y: -2.5804086, z: 8.752287}
    moveDuration: 2.1
    holdDuration: 1.6
    fieldOfView: 49
  - dialogueId: EP3_003
    speakerType: Monologue
    speakerName: 
    subtitleText: "\uB2EB\uD78C \uBB38\uACFC \uB04A\uAE34 \uBA5C\uB85C\uB514\uB294,
      \uC544\uC9C1 \uD480\uB9AC\uC9C0 \uC54A\uC740 \uC774\uC57C\uAE30\uAC00 \uB0A8\uC544
      \uC788\uC74C\uC744 \uB9D0\uD574 \uC8FC\uB294 \uB4EF\uD588\uB2E4."
    showSpeakerName: 0
    cameraPosition: {x: 0.7610698, y: 0.94867814, z: 4.8600473}
    lookAtPosition: {x: 0.049334288, y: -0.93554145, z: -0.3181162}
    moveDuration: 2.2
    holdDuration: 1.7
    fieldOfView: 46
  - dialogueId: EP3_004
    speakerType: Narration
    speakerName: 
    subtitleText: "\uC548\uCABD\uC5D0 \uB204\uAD70\uAC00\uAC00 \uC788\uC5B4"
    showSpeakerName: 0
    cameraPosition: {x: 9.406369, y: 1.0203038, z: 4.3200746}
    lookAtPosition: {x: 7.060455, y: -1.8923355, z: -4.0589986}
    moveDuration: 2
    holdDuration: 1.7
    fieldOfView: 44
  - dialogueId: EP3_005
    speakerType: Monologue
    speakerName: 
    subtitleText: "\uC870\uAC01\uC744 \uBAA8\uC544 \uC774 \uD750\uB984\uC744 \uB530\uB77C\uAC00\uBA74,\uAE30\uC5B5\uC5D0
      \uC870\uAE08 \uB354 \uAC00\uAE4C\uC6CC\uC9C8 \uC218 \uC788\uC744 \uAC83 \uAC19\uB2E4."
