  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5ad334f2656d4a2794d6f22bef1df403, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  inspectorSequenceId: EP3_LOBBY_INTRO
  inspectorShots:
  - dialogueId: EP3_001
    speakerType: Narration
    speakerName: 
    subtitleText: "\uB0AF\uC120 \uC815\uC801\uC774 \uC791\uC5C5\uC2E4 \uC548\uC5D0
      \uAC00\uB77C\uC549\uC544 \uC788\uC5C8\uB2E4."
    showSpeakerName: 0
    cameraPosition: {x: 3.2330508, y: 2.6994138, z: -17.97667}
    lookAtPosition: {x: 3.1687222, y: 2.5879512, z: -15.809563}
    moveDuration: 1.8
    holdDuration: 1.5
    fieldOfView: 50
  - dialogueId: EP3_002
    speakerType: Narration
    speakerName: 
    subtitleText: "\uC545\uAE30\uC640 \uC545\uBCF4, \uC815\uB9AC\uB418\uC9C0 \uBABB\uD55C
      \uD754\uC801\uB4E4\uC774 \uC544\uC9C1\uB3C4 \uC81C\uC790\uB9AC\uB97C \uC9C0\uD0A4\uACE0
      \uC788\uC5C8\uB2E4."
    showSpeakerName: 0
    cameraPosition: {x: 2.7090576, y: 2.9557514, z: -12.074162}
    lookAtPosition: {x: 3.2798, y: 2.7169476, z: -11.464968}
    moveDuration: 2.3
    holdDuration: 1.6
    fieldOfView: 48
  - dialogueId: EP3_003
    speakerType: Narration
    speakerName: 
    subtitleText: "\uB9C8\uCE58 \uB05D\uB0B4 \uC774\uC5B4\uC9C0\uC9C0 \uBABB\uD55C
      \uC120\uC728\uC774 \uC774 \uACF5\uAC04\uC5D0 \uB0A8\uC544 \uC788\uB294 \uAC83
      \uAC19\uC558\uB2E4."
    showSpeakerName: 0
    cameraPosition: {x: 3.7640543, y: 4.4169135, z: -8.545668}
    lookAtPosition: {x: 0.6058829, y: 3.224177, z: -11.106732}
    moveDuration: 2.4
    holdDuration: 1.7
    fieldOfView: 56
  - dialogueId: EP3_004
    speakerType: Narration
    speakerName: 
    subtitleText: "\uADF8\uB9AC\uACE0 \uADF8 \uD754\uC801\uB4E4 \uC0AC\uC774\uC5D0\uC11C,
      \uB204\uAD70\uAC00\uB97C \uAE30\uB2E4\uB9AC\uB294 \uB4EF\uD55C \uAE30\uCC99\uC774
      \uB290\uAEF4\uC84C\uB2E4."
    showSpeakerName: 0
    cameraPosition: {x: 0.80228734, y: 3.2719338, z: -11.303761}
    lookAtPosition: {x: 2.3718948, y: 2.4952836, z: -10.62665}
    moveDuration: 2
    holdDuration: 1.7
    fieldOfView: 45
  - dialogueId: EP3_005
    speakerType: Monologue
    speakerName: 
    subtitleText: "\uC774\uACF3\uC5D0 \uB0A8\uACA8\uC9C4 \uC774\uC57C\uAE30\uB97C
      \uC54C\uC544\uBCF4\uB824\uBA74, \uC870\uAE08 \uB354 \uAC00\uAE4C\uC774 \uB2E4\uAC00\uAC00
      \uBD10\uC57C \uD560 \uAC83 \uAC19\uB2E4."
    showSpeakerName: 0
    cameraPosition: {x: 3.2159946, y: 2.0639038, z: -34.09563}
    lookAtPosition: {x: 3.0115356, y: 2.1746187, z: -30.801212}
    moveDuration: 2.4
    holdDuration: 2
    fieldOfView: 43
  cutsceneResourcePath: Data/ep3_lobby_intro_cutscene
  cutsceneAssetResourcePath: Data/EP3LobbyIntroSequence
  startDelay: 0.75
  introCameraPriority: 100
  pathResolution: 24
  sceneIntroCamera: {fileID: 1963001032}
  sceneIntroPath: {fileID: 1963001012}
  sceneLookAtTarget: {fileID: 1963001021}
  syncSceneRigWithSequence: 1
  enableSubtitles: 1
  subtitleFont: {fileID: 0}
